{
  "manifest_version": 3,
  "name": "Marketly Facebook Session Helper",
  "version": "0.1.0",
  "description": "Sync fresh facebook.com cookies to Marketly.",
  "permissions": ["cookies", "alarms", "storage", "notifications"],
  "host_permissions": [
    "https://marketly-backend-870323632900.northamerica-northeast2.run.app/*",
    "https://www.facebook.com/*",
    "https://*.facebook.com/*"
  ],
  "optional_host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Marketly Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://marketly.app/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
