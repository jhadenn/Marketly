{
  "manifest_version": 3,
  "name": "Marketly Facebook Session Helper",
  "version": "0.1.0",
  "description": "Sync fresh facebook.com cookies to Marketly.",
  "permissions": ["cookies", "alarms", "storage"],
  "host_permissions": [
    "https://marketly-backend-870323632900.northamerica-northeast2.run.app/*",
    "https://www.facebook.com/*",
    "https://*.facebook.com/*"
  ],
  "optional_host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Marketly Helper"
  }
}
