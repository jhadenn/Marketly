ENV=dev
CACHE_TTL_SECONDS=60
DATABASE_URL=postgresql://user:password@localhost:5432/marketly
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REDIS_URL=
MARKETLY_SOURCE_TIMEOUT_SECONDS=18
MARKETLY_FACEBOOK_SOURCE_TIMEOUT_SECONDS=20
MARKETLY_FACEBOOK_SOURCE_TIMEOUT_SECONDS_SINGLE_SOURCE=35
MARKETLY_FACEBOOK_MAX_FETCH_LIMIT=12
MARKETLY_MULTI_SOURCE_MAX_EXPANSIONS=4
MARKETLY_DISABLE_FACEBOOK_MULTI_SOURCE_EXPANSION=true
MARKETLY_BALANCE_MULTI_SOURCE_RESULTS=true
MARKETLY_RESPONSE_CACHE_ENABLED=true
MARKETLY_RESPONSE_CACHE_TTL_SECONDS=45
MARKETLY_RESPONSE_CACHE_LOCAL_FALLBACK_ENABLED=true
MARKETLY_RESPONSE_CACHE_LOCAL_MAX_ITEMS=24
MARKETLY_RATE_LIMIT_ENABLED=true
MARKETLY_RATE_LIMIT_FAIL_OPEN=true
MARKETLY_RATE_LIMIT_LOCAL_FALLBACK_ENABLED=true
MARKETLY_RATE_LIMIT_LOCAL_MAX_KEYS=5000
MARKETLY_RATE_LIMIT_SEARCH_IP_PER_MIN=60
MARKETLY_RATE_LIMIT_SEARCH_USER_PER_MIN=30
MARKETLY_RATE_LIMIT_SAVED_MUTATION_PER_MIN=20
MARKETLY_RATE_LIMIT_FB_COOKIE_PUT_PER_HOUR=6
MARKETLY_RATE_LIMIT_FB_VERIFY_PER_HOUR=12
MARKETLY_RATE_LIMIT_FB_DELETE_PER_HOUR=20
MARKETLY_SEARCH_FETCH_CACHE_MAX_ITEMS=32
MARKETLY_SEARCH_PAGINATION_CACHE_MAX_ITEMS=8
MARKETLY_ALERTS_SEARCH_LIMIT=20
MARKETLY_ALERTS_STALE_AFTER_SECONDS=86400
MARKETLY_ALERTS_AUTO_REFRESH_WINDOW_SECONDS=300
MARKETLY_VALUATION_LOOKBACK_DAYS=120

# Gemini API configuration
GEMINI_API_KEY=your-gemini-api-key
MARKETLY_GEMINI_MODEL=gemini-2.5-flash-lite
MARKETLY_GEMINI_TIMEOUT_SECONDS=25
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Supabase auth integration (saved searches)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_or_legacy_jwt_secret
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_LISTINGS_TABLE=listings

# Facebook source integration (optional in unified /search)
MARKETLY_ENABLE_FACEBOOK=false
MARKETLY_FACEBOOK_AUTH_MODE=guest
MARKETLY_FACEBOOK_COOKIE_PATH=secrets/fb_cookies.json
MARKETLY_FACEBOOK_RETRIES=1
MARKETLY_FACEBOOK_TIMEOUT_SECONDS=20
MARKETLY_FACEBOOK_IDLE_SCROLL_LIMIT=2
MARKETLY_FACEBOOK_IDLE_SCROLL_LIMIT_SINGLE_SOURCE=5
MARKETLY_FACEBOOK_MAX_SCROLLS=12
MARKETLY_FACEBOOK_MAX_SCROLLS_SINGLE_SOURCE=40
MARKETLY_FACEBOOK_MAX_CONCURRENCY=1
MARKETLY_FACEBOOK_OVERFETCH_BUFFER=6
MARKETLY_FACEBOOK_MAX_SCRAPE_LIMIT=32
MARKETLY_FACEBOOK_MAX_SCRAPE_LIMIT_SINGLE_SOURCE=120
MARKETLY_CREDENTIALS_ENCRYPTION_KEY=replace_with_fernet_key
# copy secrets/fb_cookies.example.json -> secrets/fb_cookies.json for cookie mode

# eBay API integration
EBAY_ENV=production
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_MARKETPLACE_ID=EBAY_CA
EBAY_ACCEPT_LANGUAGE=en-CA
